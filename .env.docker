# ── Copie ce fichier en .env et remplis les valeurs ──────────────────────────

# Clé secrète JWT (change obligatoirement en production !)
JWT_SECRET=change_this_to_a_long_random_secret_key_minimum_32_chars

# URL publique du frontend (ex: http://mondomaine.com ou http://localhost)
CLIENT_URL=http://localhost

# Modèle Ollama à utiliser (mistral, llama3, etc.)
OLLAMA_MODEL=mistral
